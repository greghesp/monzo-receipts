GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Optional: enables AI fallback parsing for emails without JSON-LD structured data
# Get a key at https://openrouter.ai — free tier available
OPENROUTER_API_KEY=sk-or-...
# Default model: anthropic/claude-haiku-4-5 (cheap, fast)
# Other options: google/gemini-flash-1.5, openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
