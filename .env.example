# Base URL used for OAuth redirect URIs — set to wherever the app is accessible
# Examples: http://localhost:3000 | http://192.168.1.50:3000 | https://receipts.yourdomain.com
# IMPORTANT: This must also be registered as an authorised redirect URI in:
#   - Monzo developer portal (https://developers.monzo.com)
#   - Google Cloud Console OAuth credentials
BASE_URL=http://localhost:3000

# Monzo OAuth credentials (from https://developers.monzo.com)
# Create a Confidential client with redirect URL: {BASE_URL}/api/auth/monzo/callback
MONZO_CLIENT_ID=oauth2client_...
MONZO_CLIENT_SECRET=your-monzo-client-secret

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# OpenRouter API key for AI-assisted email/PDF parsing (get one free at openrouter.ai)
# Optional — without this, emails lacking JSON-LD structured data are recorded as no_match
OPENROUTER_API_KEY=sk-or-...

# Optional: override the AI model (default: anthropic/claude-haiku-4-5)
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Optional: override the port the container exposes on the host (default: 3000)
# PORT=3000

# Set to true if the app is served over HTTPS — enables the Secure flag on session cookies.
# Leave unset (or false) for plain HTTP (e.g. local/Unraid without SSL).
# COOKIE_SECURE=true
